# Copy to .env and adjust. The app loads backend/.env automatically.

# Required — PostgreSQL (SQLAlchemy + psycopg2)
DATABASE_URL=postgresql+psycopg2://llm_bench:llm_bench@localhost:5432/llm_bench

# At least one provider key to run non-empty benchmarks (optional for API-only smoke tests)
OPENAI_API_KEY=
# OPENAI_BENCH_MODEL=gpt-4o-mini

# ANTHROPIC_API_KEY=
# ANTHROPIC_BENCH_MODEL=claude-3-5-sonnet-latest

# Comma-separated: openai:gpt-4o-mini,anthropic:claude-3-5-sonnet-latest
# LLM_BENCH_TARGETS=

# Periodic benchmark (AsyncIO scheduler inside the API process)
LLM_BENCH_SCHEDULER_ENABLED=1
LLM_BENCH_SCHEDULE_INTERVAL_SECONDS=300
